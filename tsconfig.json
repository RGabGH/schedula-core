{
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["ES2017", "DOM"],
    "outDir": "dist/js",
    "rootDir": "./",
    "sourceMap": true,
    "removeComments": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "*.js",
    "*.map"
  ]
}